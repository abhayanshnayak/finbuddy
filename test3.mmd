flowchart TD
    User(["👤 User"])
    
    subgraph Frontend [Frontend: React SPA]
        UI["💻 React UI"]
        PDF["📄 PDF Generator"]
    end
    
    subgraph GCP [Google Cloud Platform]
        CDN["🌐 Cloud CDN"]
        Storage["📦 Cloud Storage\n(Static Hosting)"]
        
        subgraph Backend [Backend Service]
            API["⚙️ Cloud Run: FastAPI\n(Report Engine)"]
        end
        
        DB[("🗄️ Cloud Firestore\n(Report & Cache DB)")]
    end
    
    subgraph External [External APIs]
        FinAPI["📈 Financial APIs\n(Finnhub)"]
        LLM["🧠 Vertex AI\n(Gemini Pro)"]
    end

    User -->|Accesses| CDN
    CDN --> Storage
    Storage --> UI
    UI -->|1. Search Query| API
    
    API -->|2. Check Cache| DB
    DB -.->|Cache Miss| API
    
    API -->|3a. Fetch Data| FinAPI
    API -->|3b. Qualitative Synthesis| LLM
    
    API -->|4. Save Final Report| DB
    
    API -->|5. Return JSON Report| UI
    UI -->|Render| PDF
    PDF -->|Download| User
